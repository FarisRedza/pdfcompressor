<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <template class="PDFCompressor" parent="GtkApplicationWindow">
    <property name="width-request">240</property>
    <property name="title">PDF Compressor</property>
    <child>
      <object class="GtkGrid" id="grid">
        <property name="margin-top">8</property>
        <property name="margin-bottom">8</property>
        <property name="margin-start">8</property>
        <property name="margin-end">8</property>
        <property name="column-spacing">8</property>
        <property name="row-spacing">8</property>

        <child>
          <object class="GtkLabel" id="prompt">
            <property name="label">Select a PDF file to compress</property>
            <layout>
              <property name="column">0</property>
              <property name="row">0</property>
              <property name="column-span">2</property>
            </layout>
          </object>
        </child>

        <child>
          <object class="GtkEntry" id="input_file_entry">
          <property name="hexpand">true</property>
            <layout>
              <property name="column">0</property>
              <property name="row">1</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="input_file_button">
          <property name="label">Open</property>
          <property name="icon-name">document-open-symbolic</property>
            <layout>
              <property name="column">1</property>
              <property name="row">1</property>
            </layout>
          </object>
        </child>

        <child>
          <object class="GtkLabel" id="input_file_name">
            <property name="label">No file selected</property>
            <layout>
              <property name="column">0</property>
              <property name="row">2</property>
              <property name="column-span">2</property>
            </layout>
          </object>
        </child>

        <child>
          <object class="GtkLabel" id="input_file_size">
            <property name="label">N/A</property>
            <layout>
              <property name="column">0</property>
              <property name="row">3</property>
              <property name="column-span">2</property>
            </layout>
          </object>
        </child>

        <child>
          <object class="GtkLabel" id="quality_prompt">
            <property name="label">Quality level</property>
            <layout>
              <property name="column">0</property>
              <property name="row">4</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkDropDown" id="quality_dropdown">
            <layout>
              <property name="column">1</property>
              <property name="row">4</property>
            </layout>
            <property name="model">
              <object class="GtkStringList">
                <items>
                  <item translatable="yes">Low</item>
                  <item translatable="yes">Medium</item>
                  <item translatable="yes">High</item>
                </items>
              </object>
            </property>
          </object>
        </child>

        <child>
          <object class="GtkEntry" id="output_file_entry">
            <layout>
              <property name="column">0</property>
              <property name="row">5</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="output_file_button">
          <property name="label">Open</property>
            <layout>
              <property name="column">1</property>
              <property name="row">5</property>
            </layout>
          </object>
        </child>

        <child>
          <object class="GtkButton" id="compress_button">
          <property name="label">Compress</property>
            <layout>
              <property name="column">0</property>
              <property name="row">6</property>
              <property name="column-span">2</property>
            </layout>
          </object>
        </child>

      </object>
    </child>
  </template>
</interface>